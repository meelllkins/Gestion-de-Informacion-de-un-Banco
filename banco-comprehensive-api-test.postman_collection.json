    {
      "name": "1️⃣ AUTHENTICATION",
      "description": "Endpoints de autenticación y login para todos los roles",
      "item": [
        {
          "name": "1.1 ✅ Login - Internal Analyst (SUCCESS)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('analyst_token', jsonData.token);",
                  "    console.log('✅ Analyst Token guardado:', jsonData.token.substring(0, 20) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"analyst_user\",\n  \"password\": \"analyst_password\"\n}"
            },
            "url": {"raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"]}
          }
        },
        {
          "name": "1.2 ❌ Login - Username vacío",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"username\": \"\",\n  \"password\": \"analyst_password\"\n}"},
            "url": {"raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"]}
